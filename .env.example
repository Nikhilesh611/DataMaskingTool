# ─── Required — server will not start without these ───────────────────────────

# Absolute path to the directory that holds data files the API may serve.
# No trailing slash. Example: C:\data\patients  or  /srv/data/patients
DATA_DIR=

# Absolute path to the masking policy YAML file.
# Example: C:\config\policy.yaml  or  /etc/masking/policy.yaml
POLICY_PATH=

# Absolute path to the append-only operator audit log.
# The file is created on first write if it does not exist.
# Example: C:\logs\audit.log  or  /var/log/masking/audit.log
AUDIT_LOG_PATH=

# JSON object mapping bearer token strings to role names.
# Valid roles: analyst | operator | auditor
# Example: {"tok-analyst-001": "analyst", "tok-op-001": "operator", "tok-audit-001": "auditor"}
API_TOKENS={"tok-analyst-001": "analyst", "tok-op-001": "operator", "tok-audit-001": "auditor"}

# ─── Optional ─────────────────────────────────────────────────────────────────

# Python logging level for the application logger.  Default: INFO
# Valid values: DEBUG | INFO | WARNING | ERROR | CRITICAL
APP_LOG_LEVEL=INFO
